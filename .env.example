# Database
DATABASE_URL=
DIRECT_URL=

# App
# Public ORIGIN only: scheme + host, no path and no trailing slash.
# Correct:   https://your-app.onrender.com
# Wrong:     https://your-app.onrender.com/api/auth/callback
# The app appends /api/auth/callback itself to build the OAuth redirect_uri.
APP_BASE_URL=

# Hack Club OAuth
HACKCLUB_CLIENT_ID=
HACKCLUB_CLIENT_SECRET=

# Admin (comma or space separated Hack Club identity ids, e.g. "ident!abc, ident!def")
ADMIN_HACK_CLUB_IDS=

# Hackatime OAuth (confidential app; redirect URI {APP_BASE_URL}/api/hackatime/callback)
HACKATIME_CLIENT_ID=
HACKATIME_CLIENT_SECRET=
# Optional rate-limit bypass header value for the public stats endpoint
HACKATIME_BYPASS_KEYS=

# Session
SESSION_SECRET=
